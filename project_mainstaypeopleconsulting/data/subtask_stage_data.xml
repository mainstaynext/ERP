<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="subtask_stage_yet_to_start" model="project.subtask.stage">
            <field name="name">Yet to Start</field>
            <field name="sequence">10</field>
            <field name="is_closed">False</field>
            <field name="is_submit_stage">False</field>
            <field name="allowed_for_employee">True</field>
        </record>

        <record id="subtask_stage_in_progress" model="project.subtask.stage">
            <field name="name">In Progress</field>
            <field name="sequence">20</field>
            <field name="is_closed">False</field>
            <field name="is_submit_stage">False</field>
            <field name="allowed_for_employee">True</field>
        </record>

        <record id="subtask_stage_submit_for_completion" model="project.subtask.stage">
            <field name="name">Submit for Completion</field>
            <field name="sequence">30</field>
            <field name="is_closed">False</field>
            <field name="is_submit_stage">True</field>
            <field name="allowed_for_employee">True</field>
        </record>

        <record id="subtask_stage_completed" model="project.subtask.stage">
            <field name="name">Completed</field>
            <field name="sequence">40</field>
            <field name="is_closed">True</field>
            <field name="is_submit_stage">False</field>
            <field name="allowed_for_employee">False</field>
        </record>

        <record id="subtask_stage_on_hold" model="project.subtask.stage">
            <field name="name">On-Hold</field>
            <field name="sequence">50</field>
            <field name="is_closed">False</field>
            <field name="is_submit_stage">False</field>
            <field name="allowed_for_employee">True</field>
        </record>
    </data>
</odoo>