<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_subtask_stage_list" model="ir.ui.view">
        <field name="name">project.subtask.stage.list</field>
        <field name="model">project.subtask.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_closed"/>
                <field name="is_submit_stage"/>
                <field name="allowed_for_employee"/>
            </list>
        </field>
    </record>

    <record id="view_project_subtask_stage_form" model="ir.ui.view">
        <field name="name">project.subtask.stage.form</field>
        <field name="model">project.subtask.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="is_closed"/>
                        <field name="is_submit_stage"/>
                        <field name="allowed_for_employee"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_subtask_stage" model="ir.actions.act_window">
        <field name="name">Subtask Stages</field>
        <field name="res_model">project.subtask.stage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define custom stages for subtasks.
            </p>
        </field>
    </record>

    <menuitem id="menu_project_subtask_stage"
              name="Subtask Stages"
              parent="project.menu_main_pm"
              action="action_project_subtask_stage"
              sequence="100"/>
</odoo>