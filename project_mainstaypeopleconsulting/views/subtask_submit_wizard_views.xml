<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subtask_submit_wizard_form" model="ir.ui.view">
        <field name="name">subtask.submit.wizard.form</field>
        <field name="model">subtask.submit.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="task_id" readonly="1"/>
                        <field name="comment" required="1" placeholder="Enter your completion comments..."/>
                        <field name="supporting_link" required="1" placeholder="https://yourcompany.sharepoint.com/..."/>
                    </group>
                    <footer>
                        <button name="action_submit" string="Submit for Approval" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>