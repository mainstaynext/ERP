<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subtask_approval_wizard_form" model="ir.ui.view">
        <field name="name">subtask.approval.wizard.form</field>
        <field name="model">subtask.approval.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="task_id" readonly="1"/>
                        <field name="comment" required="1"/>
                        <field name="supporting_link"
                               placeholder="https://yourcompany.sharepoint.com/..."/>
                    </group>
                    <footer>
                        <button name="action_confirm_approve"
                                string="Approve"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-default"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
